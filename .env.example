# Required: Resend API key (transactional email). Get one at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Required for the login gate: secret used to sign the bb_session cookie + magic-link
# tokens (HMAC-SHA256). Use a long random string (e.g. `openssl rand -hex 32`).
# Falls back to WHOP_API_KEY if unset, but set a dedicated value in production.
AUTH_SECRET=change-me-to-a-long-random-string

# Base URL used to build magic-link emails + auth redirects. No trailing slash.
SITE_URL=https://benjisblueprints.com

# Optional overrides (sensible defaults are baked in):
# Verified Resend sender. Must be a domain verified in your Resend account.
EMAIL_FROM=Benji <ben@benjisaiempire.com>
# Where new-lead notifications go (comma-separated).
ADMIN_EMAILS=ben@advancedmarketing.co
# Public Google Drive folder of the business plans.
NEXT_PUBLIC_PLANS_URL=https://drive.google.com/drive/folders/1I--Aa_uMJMtv5p95IHHBcEGPJj1gEA0u

# Monetization links on the /plans library page (swap in your affiliate URLs):
# Shopify Partner/affiliate link (product businesses).
NEXT_PUBLIC_SHOPIFY_URL=https://www.shopify.com/free-trial
# GoHighLevel affiliate link (service businesses — recurring revenue).
NEXT_PUBLIC_GHL_URL=https://www.gohighlevel.com
# $99/mo Slack community + live calls checkout link.
NEXT_PUBLIC_SLACK_URL=#
# Free Whop community (the gate — magic-link emails + CTAs point here).
NEXT_PUBLIC_WHOP_URL=https://whop.com/benjis-business-blueprints/free-business-plans-suppliers

# --- Whop auto-enroll (optional) ---
# Server API key for the Whop app (also used as the session-secret fallback + webhook lookups).
WHOP_API_KEY=
# Free community company id (members of this whop unlock the content).
WHOP_COMPANY_ID=biz_n7oyqtb2Enrre3
# Free plan/access-pass id to comp new users into on verify. If unset, auto-enroll
# is skipped (we still email/show the community join link). Whop's API has no
# documented "create free membership by email" mutation — this is best-effort.
WHOP_FREE_PLAN_ID=
# Whop webhook signing secret (Whop dashboard → Webhooks). Used by /api/whop/webhook → GHL.
WHOP_WEBHOOK_SECRET=

# --- GoHighLevel CRM sync (optional) ---
GHL_API_KEY=
GHL_LOCATION_ID=
